      },
      "properties": {
        "name": "Wagdi (Vagadi / Bhili)",
        "type": "language_region",
        "category": "custom",
        "district": "Banswara, Dungarpur, southern Pratapgarh",
        "speakers": "~4 million",
        "state": "Rajasthan",
        "source": "Sikhwal Manchitrawali (16th ed.) + Census 2011 (mother tongue)",
        "lastUpdated": "2026-07-12",
        "icon": "🗣",
        "notes": {
          "facts": [
            "Language of the Vagad tribal belt — a Bhili-Gujarati transitional dialect spoken by the Bhil, Damor and Meena communities.",
            "Classified by linguists as a Bhil language rather than Rajasthani; contains many Austroasiatic substrate loanwords.",
            "Ganeshi Lal Vyas (1912-1997) is Wagdi's most-celebrated modern folk-song composer."
          ]
        },
        "districts_included": [
          "Banswara",
          "Dungarpur",
          "Pratapgarh"
        ]
      }
    },
