      "properties": {
        "name": "Dhundhari (Jaipuri)",
        "type": "language_region",
        "category": "custom",
        "district": "Jaipur, Dausa, Sawai Madhopur, Tonk",
        "speakers": "~9 million",
        "state": "Rajasthan",
        "source": "Sikhwal Manchitrawali (16th ed.) + Census 2011 (mother tongue)",
        "lastUpdated": "2026-07-12",
        "icon": "🗣",
        "notes": {
          "facts": [
            "Language of the Dhundhar region (historic Kachhawaha territory around Jaipur); closer to Braj Bhasha and Khari Boli Hindi than western Rajasthani.",
            "Sawai Jai Singh II patronised Dhundhari literature at the Jaipur court in the 18th c.",
            "Also called Jaipuri; the vernacular of most day-to-day Jaipur commerce alongside Hindi."
          ]
        },
        "districts_included": [
          "Dausa",
          "Jaipur",
          "Sawai Madhopur",
          "Tonk"
        ]
      }
