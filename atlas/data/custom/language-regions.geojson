      "properties": {
        "name": "Hadoti",
        "type": "language_region",
        "category": "custom",
        "district": "Kota, Bundi, Baran, Jhalawar",
        "speakers": "~4 million",
        "state": "Rajasthan",
        "source": "Sikhwal Manchitrawali (16th ed.) + Census 2011 (mother tongue)",
        "lastUpdated": "2026-07-12",
        "icon": "🗣",
        "notes": {
          "facts": [
            "Language of the Hadoti region (Chauhan-Hada territory of Bundi-Kota); influenced by Malvi to the east and Dhundhari to the north.",
            "Distinct vocabulary borrowed from Malwa plateau traditions and Bhil substrates.",
            "The Bundi and Kota court histories, and Bhavani Singh's 'Hadoti Vachanika', are the school's landmark texts."
          ]
        },
        "districts_included": [
          "Baran",
          "Bundi",
          "Jhalawar",
          "Kota"
        ]
      }
    },
