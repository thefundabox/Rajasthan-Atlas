      },
      "properties": {
        "name": "Malvi",
        "type": "language_region",
        "category": "custom",
        "district": "Jhalawar, Baran (Rajasthan share)",
        "speakers": "~1 million (Rajasthan share)",
        "state": "Rajasthan",
        "source": "Sikhwal Manchitrawali (16th ed.) + Census 2011 (mother tongue)",
        "lastUpdated": "2026-07-12",
        "icon": "🗣",
        "notes": {
          "facts": [
            "Language of the Malwa plateau — Rajasthan's share is limited to Jhalawar-Baran (former Kota state territory that lay on the Malwa plateau).",
            "Bulk of Malvi speakers live in Madhya Pradesh; Rajasthan holds the northern fringe.",
            "Distinct enough from Hadoti (its western neighbour) that most linguists treat it as a separate Central-Zone Hindi dialect, not Rajasthani."
          ]
        },
        "districts_included": [
          "Baran",
          "Jhalawar"
        ]
      }
    },
