      },
      "properties": {
        "name": "Kanhaiyalal Sethia — Padma Shri Poet",
        "type": "literary_figure",
        "category": "custom",
        "district": "Bikaner (Sujangarh, Churu)",
        "genre": "Rajasthani + Hindi poetry",
        "notes": {
          "facts": [
            "Padma Shri (2004) poet whose \"Dharti Dhora Ri\" is Rajasthan's unofficial anthem in Rajasthani.",
            "Wrote in both Rajasthani and Hindi; his volumes traverse Chhayavad, progressivism and Nayi Kavita.",
            "The Kanhaiyalal Sethia Literary Award (Rajasthan Sahitya Akademi) is given to the best Rajasthani-language book of the year."
          ],
          "significance": "high"
        },
        "state": "Rajasthan",
