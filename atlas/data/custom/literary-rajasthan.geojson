    {
      "type": "Feature",
      "id": "lit-rangeya-raghav-jaipur",
      "geometry": {
        "type": "Point",
        "coordinates": [
          75.822,
          26.923
        ]
      },
      "properties": {
        "name": "Rangeya Raghav — Kab Tak Pukaroon (1957)",
        "type": "literary_figure",
        "category": "custom",
        "district": "Rajasthan-wide",
        "genre": "Hindi novel + short story",
        "notes": {
          "facts": [
            "11 story collections + numerous novels in a life of only 39 years — Rajasthan's most prolific 20th-century writer.",
            "\"Kab Tak Pukaroon\" (1957) put nomadic and tribal Rajasthan on the mainstream Hindi literary map; his \"Murdon Ka Teela\" is a landmark novel of the Indus-Sarasvati site.",
            "His story \"Gadal\" is treated as required-reading in Hindi MA syllabi."
          ],
          "significance": "high"
        },
        "state": "Rajasthan",
        "source": "Rajasthan Adhyan Class 12 Ch 9 (Literary Rajasthan)",
