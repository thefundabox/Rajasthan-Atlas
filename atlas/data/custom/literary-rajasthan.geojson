      "id": "lit-suryamall-misran-bundi",
      "geometry": {
        "type": "Point",
        "coordinates": [
          75.638,
          25.437
        ]
      },
      "properties": {
        "name": "Suryamall Misran — Bundi Court Poet",
        "type": "literary_figure",
        "category": "custom",
        "district": "Bundi",
        "genre": "Rajasthani heroic (Dingal) verse",
        "notes": {
          "facts": [
            "Court poet of Bundi (1815-1868); his epic \"Vansh Bhaskar\" is the largest Dingal-verse dynastic history in Rajasthani.",
            "His 1857 correspondence with Thakur Phool Singh of Pipalya sharply criticised pro-British Rajput rulers — treated as Rajputana's first Dingal protest literature.",
            "Suryamall's courtroom in the Bundi Chitrashala inspired the Hadoti painting school's literary-illustration tradition."
          ],
          "significance": "high"
        },
        "state": "Rajasthan",
        "source": "Rajasthan Adhyan Class 12 Ch 9 (Literary Rajasthan)",
