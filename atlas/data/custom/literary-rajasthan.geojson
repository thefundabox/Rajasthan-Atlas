        ]
      },
      "properties": {
        "name": "Bankidas — Marwar Charan Poet",
        "type": "literary_figure",
        "category": "custom",
        "district": "Jodhpur",
        "genre": "Rajasthani Dingal history",
        "notes": {
          "facts": [
            "Charan court poet of Marwar under Man Singh Rathore (r. 1803-43); his \"Bankidas Ki Khyat\" is a Rajasthani chronicle across the entire Marwar dynasty.",
            "Bankidas's verses condemning Rajput rulers who \"served as slaves\" of the British foreshadowed the 1857-Auwa spirit.",
            "The Bankidas Prasasti at Nagaur is a rare Rajasthani-language inscription of the early 19th century."
          ],
          "significance": "high"
        },
        "state": "Rajasthan",
        "source": "Rajasthan Adhyan Class 12 Ch 9 (Literary Rajasthan)",
