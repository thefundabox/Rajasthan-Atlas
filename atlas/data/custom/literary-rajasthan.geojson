    {
      "type": "Feature",
      "id": "lit-dhola-maru-marwar",
      "geometry": {
        "type": "Point",
        "coordinates": [
          72.628,
          25.749
        ]
      },
      "properties": {
        "name": "Dhola-Maru — Marwar Folk Epic",
        "type": "literary_figure",
        "category": "custom",
        "district": "Marwar (Sirohi-Barmer)",
        "genre": "Rajasthani folk romance (Dingal)",
        "notes": {
          "facts": [
            "The 14th-century \"Dhola-Maru-ra Duha\" is Rajasthani's finest medieval folk romance — the Pungal princess Marvani's eight-year separation from her Narwar husband Dhola.",
            "A Dingal-style oral epic sung by Charans and Manganiyars; performances still open with the Dhola-Maru sthayi.",
            "A model for later Rajasthani love-cycles (Nihalde-Sultan, Beeja-Sorath, Momal-Mahendra)."
          ],
          "significance": "high"
        },
        "state": "Rajasthan",
        "source": "Rajasthan Adhyan Class 12 Ch 9 (Literary Rajasthan)",
