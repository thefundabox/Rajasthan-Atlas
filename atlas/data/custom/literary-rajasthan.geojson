      },
      "properties": {
        "name": "Chandradhar Sharma \"Guleri\" — Usne Kaha Tha (1915)",
        "type": "literary_figure",
        "category": "custom",
        "district": "Jaipur",
        "genre": "Hindi short story",
        "notes": {
          "facts": [
            "The three-story author whose 1915 \"Usne Kaha Tha\" (Saraswati magazine) remains one of the finest short stories in Hindi literature — a Sikh soldier's First World War memory.",
            "Contemporary of Ojha and Deviprasad Mishra; formed the Nagari Pracharini Patrika editorial trio.",
            "Guleri set the modernist Hindi short-story template used by Yashpal, Premchand and Mannu Bhandari."
          ],
          "significance": "high"
        },
        "state": "Rajasthan",
        "source": "Rajasthan Adhyan Class 12 Ch 9 (Literary Rajasthan)",
