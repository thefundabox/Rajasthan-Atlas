      },
      "properties": {
        "name": "Mannu Bhandari — Mahabhoj / Aapka Bunty",
        "type": "literary_figure",
        "category": "custom",
        "district": "Bhanpura (MP-Rajasthan border)",
        "genre": "Hindi novel + screenplay",
        "notes": {
          "facts": [
            "\"Mahabhoj\" (1979) — signature political novel of caste violence, adapted for stage across India by NSD.",
            "\"Aapka Bunty\" (1971) — one of Hindi's most-read novels on modern Indian childhood and divorce.",
            "Screenplay for Basu Chatterjee's \"Rajnigandha\" and Yash Chopra's \"Silsila\" credited her among Hindi cinema's finest women screenwriters."
          ],
          "significance": "high"
        },
        "state": "Rajasthan",
        "source": "Rajasthan Adhyan Class 12 Ch 9 (Literary Rajasthan)",
