      "id": "lit-chand-bardai-ajmer",
      "geometry": {
        "type": "Point",
        "coordinates": [
          74.634,
          26.449
        ]
      },
      "properties": {
        "name": "Chand Bardai — Prithviraj Raso",
        "type": "literary_figure",
        "category": "custom",
        "district": "Ajmer (Chauhan court)",
        "genre": "Rajasthani-Braj heroic epic",
        "notes": {
          "facts": [
            "Court poet of Prithviraj Chauhan III (12th c.) — his 100,000-couplet \"Prithviraj Raso\" is the earliest recorded Rajasthani epic.",
            "Considered the founding text of the Dingal poetic tradition; disputed for its historical accuracy but foundational for Rajputana literary consciousness.",
            "The Ajmer Chauhan court where Chand composed became the template for the Bardic (Charan-Bhat) tradition across Rajputana."
          ],
          "significance": "high"
        },
        "state": "Rajasthan",
        "source": "Rajasthan Adhyan Class 12 Ch 9 (Literary Rajasthan)",
