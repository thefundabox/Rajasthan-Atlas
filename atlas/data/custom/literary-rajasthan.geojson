      "properties": {
        "name": "Nand Chaturvedi — Udaipur Poet-Critic",
        "type": "literary_figure",
        "category": "custom",
        "district": "Udaipur",
        "genre": "Hindi poetry + criticism + memoir",
        "notes": {
          "facts": [
            "Central Sahitya Akademi Award (2008) for \"Yaha Samay Manghne Aane Ka Hai\" — a landmark of Rajasthani-Hindi poetry.",
            "His memoir \"Ateet Raag\" (2010) is Rajasthan's finest 20th-century literary autobiography.",
            "Long-time associate of the Rajasthan Sahitya Akademi and the Vishvavidyalaya of Rajasthan, Udaipur."
          ],
          "significance": "high"
