      },
      "properties": {
        "name": "Muni Jin Vijay — Jain Research Pioneer",
        "type": "literary_figure",
        "category": "custom",
        "district": "Udaipur (Rajputana Jain circuits)",
        "genre": "Sanskrit-Prakrit editing + Jain manuscript research",
        "notes": {
          "facts": [
            "Pioneer of Jain manuscript research in early 20th century Rajasthan; catalogued the Jaisalmer, Patan and Bikaner bhandars.",
            "Founding director of the Rajasthan Prachyavidya Pratishthan (Jodhpur, 1950) — India's premier Rajasthani-Sanskrit research library.",
            "His edited series \"Singhi Jaina Granthmala\" preserved hundreds of medieval Rajasthan Jain texts."
          ],
          "significance": "high"
        },
        "state": "Rajasthan",
