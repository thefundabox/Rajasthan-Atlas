      "properties": {
        "name": "Harish Bhadani — Editor of Vatayan",
        "type": "literary_figure",
        "category": "custom",
        "district": "Bikaner",
        "genre": "Hindi Nayi Kavita + little-magazine editor",
        "notes": {
          "facts": [
            "Editor-poet of the little magazine \"Vatayan\" (Bikaner) — nurtured a generation of Rajasthan's Sathottari Kavita.",
            "His poetry cycle \"Sadi Ko Saakhya Karein\" appears in Kendra Sahitya Akademi anthologies.",
            "Bhadani's magazine editing paralleled Prakash Jain's \"Lahar\" and Kamar Mewari's \"Sambodhan\" in shaping Rajasthan's Hindi literary sphere."
          ],
          "significance": "high"
        },
        "state": "Rajasthan",
