      "id": "lit-vijay-singh-pathik",
      "geometry": {
        "type": "Point",
        "coordinates": [
          75.283,
          25.183
        ]
      },
      "properties": {
        "name": "Vijay Singh Pathik — Poet-Activist of Bijolia",
        "type": "literary_figure",
        "category": "custom",
        "district": "Bhilwara (Bijolia)",
        "genre": "Nationalist poetry + prose journalism",
        "notes": {
          "facts": [
            "Founder-editor of Rajasthan Kesari (Wardha, then Ajmer, 1920) — the paper that took the Bijolia peasant story national.",
            "Wrote in Braj and Khadi Boli; his songs anchored the Bijolia satyagraha for 25 years.",
            "Both writer and organiser — remembered together with Kesari Singh Barhath as the founder of Rajasthan's literary-political tradition."
          ],
          "significance": "high"
        },
        "state": "Rajasthan",
        "source": "Rajasthan Adhyan Class 12 Ch 9 (Literary Rajasthan)",
