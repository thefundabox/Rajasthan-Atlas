":"Feature","id":"peak-morraka-dungar","properties":{"name":"Morraka Dungar","type":"peak","category":"physical","state":"Rajasthan","elevation_m":426,"range":"Vindhyan-Aravalli transition (Karauli hills)","district":"Karauli","division":"Bharatpur","kind":"peak","source":"OSM","lastUpdated":"2026-07-06","centroid":[76.79258,26.81557],"labelAnchor":[76.79258,26.81557],"bbox":[76.79258,26.81557,76.79258,26.81557],"geometryQuality":"point","notes":{"facts":["A low, isolated hill (dungar) in the Karauli plateau.","Sits at the transition where the Aravalli fades into the Vindhyan sandstone scarplands."],"mnemonic":"","significance":"high","confusedWith":[]},"ecology":{"flora":[],"fauna":[],"ecosystem":""},"governance":{"authority":"","status":""},"timeline":[]},"geometry":{"type":"Point","coordinates":[76.7925829,26.8155732]}},{"type":"Feature","id":"peak-achalgarh-fort","properties":{"name":"Achalgarh","type":"peak","category":"physical","state":"Rajasthan","elevation_m":1380,"range":"Aravalli \u00b7 Mount Abu massif","district":"Sirohi","division":"Jodhpur","kind":"hill fort","source":"OSM (historic=fort) + Rajasthan Tourism Department + Wikipedia","lastUpdated":"2026-07-06","centroid":[72.7629,24.631],"labelAnchor":[72.7629,24.631],"bbox":[72.7629,24.631,72.7629,24.631],"geometryQuality":"point","notes":{"facts":["Aravalli fort-summit north of Mount Abu at ~1,380 m.","15th-century fort built by Rana Kumbha over 8th-century Paramara foundations.","Achaleshwar Mahadev temple within the walls."],"mnemonic":"","significance":"very-high","confusedWith":[]},"ecology":{"flora":[],"fauna":[],"ecosystem":""},"governance":{"authority":"","status":""},"timeline":[]},"geometry":{"type":"Point","coordinates":[72.7629,24.631]}},{"type":"Feature","id":"peak-kumbhalgarh-fort","properties":{"name":"Kumbhalgarh","type":"peak","category":"physical","state":"Rajasthan","elevation_m":1180,"range":"Aravalli \u00b7 central","district":"Rajsamand","division":null,"kind":"hill fort","source"